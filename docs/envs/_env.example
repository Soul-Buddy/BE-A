# ============================================================
# .env.example — 환경변수 목록 템플릿
# 담당: BE-C 헌영
# ⚠️ 이 파일은 Git에 커밋합니다 (값 없는 예시용).
# ⚠️ 실제 값이 든 .env 파일은 .gitignore에 추가하세요.
# 사용법: 이 파일을 복사해서 .env로 만들고 값을 채우세요.
#   cp .env.example .env
# ============================================================

# ── 데이터베이스 ──
# ⚠️ DB명: soul_buddy (언더스코어 포함) — soul_buddy_schema_v2.sql 정본 기준
DB_URL=jdbc:mysql://localhost:3306/soul_buddy?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
DB_USERNAME=root
DB_PASSWORD=

# ── AI (OpenAI GPT-4o) ──
OPENAI_API_KEY=

# ── OAuth2 (Google) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth2 (Kakao) ──
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── JWT ──
JWT_SECRET=

# ── 서버 ──
SERVER_PORT=8080
CORS_ORIGIN=http://localhost:3000

# ── Railway 배포 시 추가 ──
# RAILWAY_ENVIRONMENT=production
# CORS_ORIGIN=https://your-frontend.vercel.app
