# Soul Buddy 환경변수 예시 (v4.2 기준)
# 이 파일은 git에 올라가는 템플릿입니다.
# 실제 키는 .env 파일에 채워 넣고, .env는 .gitignore에 등록되어 있습니다.
# 팀원에게는 메신저 등으로 .env 파일 자체를 1회 공유하면 됩니다.

# === DB ===
DB_URL=jdbc:mysql://localhost:3306/soul_buddy?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=비밀번호입력

# === JWT ===
JWT_SECRET=최소32자이상의시크릿키입력
JWT_EXPIRATION_MS=86400000

# === Google OAuth ===
GOOGLE_CLIENT_ID=구글클라이언트ID
GOOGLE_CLIENT_SECRET=구글클라이언트시크릿

# === CLOVA Studio (HyperCLOVA X) ===
CLOVA_API_KEY=nv-XXXXXXXXXXXXXXXXXXXX
CLOVA_HOST=https://clovastudio.stream.ntruss.com

# CLOVA Request ID (5종 + 요약 = 6종)
CLOVA_REQUEST_ID_PERSONA_FRIEND=
CLOVA_REQUEST_ID_PERSONA_COUNSELOR=
CLOVA_REQUEST_ID_CLASSIFY_EMOTION=
CLOVA_REQUEST_ID_CLASSIFY_RISK=
CLOVA_REQUEST_ID_CLASSIFY_INTERVENTION=
CLOVA_REQUEST_ID_SUMMARY=

# CLOVA Endpoint (필요 시 override, 기본값은 application.yml 참고)
# CLOVA_HCX005_FRIEND_ENDPOINT=/v3/chat-completions/HCX-005
# CLOVA_HCX005_COUNSELOR_ENDPOINT=/v3/chat-completions/HCX-005
# CLOVA_HCX007_ENDPOINT=/v3/chat-completions/HCX-007
# CLOVA_DASH002_EMOTION_ENDPOINT=/v3/chat-completions/HCX-DASH-002
# CLOVA_DASH002_RISK_ENDPOINT=/v3/chat-completions/HCX-DASH-002
# CLOVA_DASH002_INTERVENTION_ENDPOINT=/v3/chat-completions/HCX-DASH-002

# === RAG (Vector Store) ===
RAG_ENABLED=false
VECTOR_STORE_TYPE=NONE
VECTOR_STORE_URL=

# === Server / CORS ===
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
